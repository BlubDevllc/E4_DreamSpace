# DreamSpace Application Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit the actual .env file to version control

# ===== Application Settings =====
APP_NAME=DreamSpace
APP_ENV=development
APP_VERSION=1.0.0
APP_DEBUG=true
APP_URL=http://localhost/persoonlijk/school%20naar%20persnenal/E4_DreamSpace/src/

# ===== Database Configuration =====
DB_HOST=localhost
DB_PORT=3306
DB_NAME=dreamspace_db
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# ===== Session Configuration =====
SESSION_LIFETIME=1440
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SECURE=false

# ===== Security Settings =====
BCRYPT_ROUNDS=10
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRATION=900

# ===== Email Configuration =====
MAIL_DRIVER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=465
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=noreply@dreamspace.game
MAIL_FROM_NAME=DreamSpace

# ===== Logging =====
LOG_CHANNEL=singlefile
LOG_LEVEL=info

# ===== API Configuration =====
API_RATE_LIMIT=100
API_RATE_WINDOW=3600

# ===== Feature Flags =====
FEATURE_USER_REGISTRATION=true
FEATURE_TRADING=true
FEATURE_ADMIN_PANEL=true
FEATURE_NOTIFICATIONS=true
